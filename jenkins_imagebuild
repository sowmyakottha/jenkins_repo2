pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/sowmyakottha/jenkins_repo2.git'
            }
        }

        stage('Build Maven') {
            steps {
                dir('Docker_file') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('Docker_file') {
                    sh 'docker build -t myapp:latest .'
                }
            }
        }
    }
}
