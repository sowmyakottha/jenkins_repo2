pipeline {
    agent any

    environment {
        IMAGE_NAME = "java-jenkins-app"
        TAG = "latest"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/sowmyakottha/jenkins_repo2.git'
            }
        }

        stage('Build Maven') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$TAG .'
            }
        }

        stage('Check Images') {
            steps {
                sh 'docker images'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker rm -f javaapp || true'
                sh 'docker run -d --name javaapp -p 8080:8080 $IMAGE_NAME:$TAG'
            }
        }
    }
}
